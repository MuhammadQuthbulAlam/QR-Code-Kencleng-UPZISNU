# ============================================================
# .env.example
# Template variabel environment yang dibutuhkan aplikasi
#
# CARA PENGGUNAAN:
# 1. Copy file ini: cp .env.example .env.local
# 2. Isi nilai yang sesuai di .env.local
# 3. JANGAN commit .env.local ke Git!
# ============================================================

# ── Database PostgreSQL ──────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Contoh lokal:
DATABASE_URL="postgresql://postgres:password@localhost:5432/nu_portal_db"
# Contoh dengan Supabase:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"
# Contoh dengan Railway:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/railway"

# ── NextAuth.js Konfigurasi ──────────────────────────────────
# Secret untuk enkripsi session token
# Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-random-string-yang-panjang-dan-aman"

# URL aplikasi (ganti saat deploy ke production)
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth Providers (Opsional) ───────────────────────────────
# Google OAuth - Dapatkan dari: https://console.developers.google.com
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Konfigurasi Aplikasi ─────────────────────────────────────
# Environment: development | staging | production
NODE_ENV="development"

# Nama aplikasi (tampil di UI)
NEXT_PUBLIC_APP_NAME="Portal Nahdlatul Ulama"

# URL base aplikasi (accessible di client-side karena NEXT_PUBLIC_)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Upload File (Jika menggunakan layanan cloud) ─────────────
# Cloudinary (opsional, untuk upload gambar)
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# ── Email (Untuk fitur notifikasi) ──────────────────────────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
